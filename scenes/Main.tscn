text = "Balatro Logic Prototype"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="RootMargin/Layout"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Godot 4.6 Mono · C# stable runtime · GDScript hot-update rules · SDD workflow"
horizontal_alignment = 1

[node name="Panel" type="PanelContainer" parent="RootMargin/Layout"]
layout_mode = 2
