[node name="PanelMargin" type="MarginContainer" parent="RootMargin/Layout/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 22
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 22

[node name="PanelLayout" type="VBoxContainer" parent="RootMargin/Layout/Panel/PanelMargin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Status" type="Label" parent="RootMargin/Layout/Panel/PanelMargin/PanelLayout"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Runtime ready"

[node name="Description" type="RichTextLabel" parent="RootMargin/Layout/Panel/PanelMargin/PanelLayout"]
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
text = "[b]Current scaffold[/b]\n- Visible Godot startup scene\n- C# rule engine and state model compile successfully\n- GDScript joker rules are ready for hot-update loading\n- Specs and golden cases live under content/specs and content/tests\n\nNext milestone: wire this UI to the C# GameBootstrap simulation and show evaluated hand results."
fit_content = true

[node name="ButtonRow" type="HBoxContainer" parent="RootMargin/Layout"]
